{
  "name": "try-npm-workspaces",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "build": "tsc -b && npm run build --workspace=frontend",
    "clean": "tsc -b --clean",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run backend\" \"npm run frontend\"",
    "backend": "npm run dev --workspace=backend",
    "frontend": "npm run dev --workspace=frontend"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "concurrently": "^9.0.0",
    "typescript": "^5.6.0"
  }
}
