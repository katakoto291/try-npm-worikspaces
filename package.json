{
  "name": "try-npm-workspaces",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "build": "tsc -b && npm run build --workspace=backend && npm run build --workspace=frontend",
    "build:frontend": "tsc -b && npm run build --workspace=frontend",
    "clean": "tsc -b --clean && rm -rf backend/dist",
    "type-check": "tsc -b && npm run type-check --workspace=backend",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run backend\" \"npm run frontend\"",
    "backend": "npm run dev --workspace=backend",
    "frontend": "npm run dev --workspace=frontend",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@types/node": "24.12.2",
    "concurrently": "9.2.1",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
