{
  "name": "try-npm-workspaces",
  "version": "1.0.0",
  "lockfileVersion": 3,
  "requires": true,
  "packages": {
    "": {
      "name": "try-npm-workspaces",
      "version": "1.0.0",
      "workspaces": [
        "shared",
        "backend",
        "frontend"
      ]
    },
    "backend": {
      "name": "@try/backend",
      "version": "1.0.0",
      "dependencies": {
        "@try/shared": "*"
      }
    },
    "frontend": {
      "name": "@try/frontend",
      "version": "1.0.0",
      "dependencies": {
        "@try/shared": "*"
      }
    },
    "node_modules/@try/backend": {
      "resolved": "backend",
      "link": true
    },
    "node_modules/@try/frontend": {
      "resolved": "frontend",
      "link": true
    },
    "node_modules/@try/shared": {
      "resolved": "shared",
      "link": true
    },
    "shared": {
      "name": "@try/shared",
      "version": "1.0.0"
    }
  }
}
